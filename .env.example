# Server
PORT=3000
NODE_ENV=development

# JWT (uzun, rastgele bir string — `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# İlk kurulumda oluşturulacak default admin (init-db çalışınca kullanılır)
DEFAULT_ADMIN_EMAIL=admin@formelektrik.com
DEFAULT_ADMIN_PASSWORD=Admin!2026
DEFAULT_ADMIN_NAME=Form Elektrik Admin

# Email (SMTP) — boş bırakırsanız mail gönderimi devre dışı, kayıtlar yine tutulur.
# Bu değerler admin panel > Ayarlar'dan da yönetilebilir (DB öncelikli).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Form Elektrik <no-reply@formelektrik.com>"
LEAD_NOTIFY_TO=info@formelektrik.com
APPOINTMENT_NOTIFY_TO=info@formelektrik.com

# Garanti Sorgulama — Navision ERP (gizli /garanti sayfası).
# Bu değerler admin panel > Garanti Sorgulama'dan da yönetilebilir (DB öncelikli).
# URL'de {serial} yer tutucusu kullanılabilir; yoksa ?serial=... otomatik eklenir.
NAVISION_API_URL=
NAVISION_USER=
NAVISION_PASS=

# reCAPTCHA v2 (garanti sayfası bot koruması) — https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=
